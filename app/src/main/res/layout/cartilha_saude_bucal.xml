<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tituloCartilha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cartilha de Saúde Bucal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="16dp" />

            <ImageView
                android:id="@+id/imagemCartilha"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:src="@drawable/ic_launcher_foreground"
                android:scaleType="centerCrop"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/textoCartilha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aqui será exibido o conteúdo da cartilha de saúde bucal. Em breve adicionaremos as telas interativas com navegação entre páginas."
                android:textSize="16sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
